# Ignore build, install, and log folders sitting inside the package
build/
install/
log/
.colcon/

# Ignore the downloaded model weights, but make sure directory is tracked
models/*
!models/.gitkeep

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore IDE-specific configurations
.vscode/
.idea/
*.user
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Ignore compiled C++ objects that might be generated locally by mistake
*.o
*.so
*.a
